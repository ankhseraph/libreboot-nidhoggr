From: ankhseraph <florin.anghel@man.ase.ro>
Date: Wed, 21 May 2026 00:00:00 +0000
Subject: [PATCH] t480: personal customizations for nidhoggr build

Based on Libreboot 26.01 (git tag 26.01), ThinkPad T480 (non-S), 16MB SPI NOR.

- CONFIG_FSP_HYPERTHREADING=y — enable SMT, 8 threads on i5/i7-8xxx
- CONFIG_H8_FN_CTRL_SWAP=y — fn/ctrl swap at EC level, affects all OSes
- payload_grubsea — grub primary, seabios accessible from grub menu
- set timeout=0 — no grub delay

---
 config/coreboot/t480_vfsp_16mb/config/libgfxinit_corebootfb | 4 ++--
 config/coreboot/t480_vfsp_16mb/config/libgfxinit_txtmode     | 4 ++--
 config/coreboot/t480_vfsp_16mb/target.cfg                    | 2 +-
 config/grub/xhci_nvme/config/payload                         | 6 +-----
 4 files changed, 7 insertions(+), 9 deletions(-)

diff --git a/config/coreboot/t480_vfsp_16mb/config/libgfxinit_corebootfb b/config/coreboot/t480_vfsp_16mb/config/libgfxinit_corebootfb
index 9e54ced6..aa186a3b 100644
--- a/config/coreboot/t480_vfsp_16mb/config/libgfxinit_corebootfb
+++ b/config/coreboot/t480_vfsp_16mb/config/libgfxinit_corebootfb
@@ -354,7 +354,7 @@ CONFIG_INTEL_CAR_NEM_ENHANCED=y
 # CONFIG_USE_INTEL_FSP_MP_INIT is not set
 CONFIG_CPU_SUPPORTS_PM_TIMER_EMULATION=y
 CONFIG_HAVE_HYPERTHREADING=y
-# CONFIG_FSP_HYPERTHREADING is not set
+CONFIG_FSP_HYPERTHREADING=y
 # CONFIG_INTEL_KEYLOCKER is not set
 # CONFIG_SOC_INTEL_COMMON_BLOCK_PRMRR_SIZE_MAX is not set
 # CONFIG_SOC_INTEL_COMMON_BLOCK_PRMRR_SIZE_256MB is not set
@@ -508,7 +508,7 @@ CONFIG_EC_LENOVO_H8=y
 CONFIG_H8_BEEP_ON_DEATH=y
 CONFIG_H8_FLASH_LEDS_ON_DEATH=y
 CONFIG_H8_SUPPORT_BT_ON_WIFI=y
-# CONFIG_H8_FN_CTRL_SWAP is not set
+CONFIG_H8_FN_CTRL_SWAP=y
 CONFIG_H8_HAS_BAT_THRESHOLDS_IMPL=y
 CONFIG_H8_HAS_PRIMARY_FN_KEYS=y
 CONFIG_H8_HAS_LEDLOGO=y
diff --git a/config/coreboot/t480_vfsp_16mb/config/libgfxinit_txtmode b/config/coreboot/t480_vfsp_16mb/config/libgfxinit_txtmode
index bcf90216..76345042 100644
--- a/config/coreboot/t480_vfsp_16mb/config/libgfxinit_txtmode
+++ b/config/coreboot/t480_vfsp_16mb/config/libgfxinit_txtmode
@@ -352,7 +352,7 @@ CONFIG_INTEL_CAR_NEM_ENHANCED=y
 # CONFIG_USE_INTEL_FSP_MP_INIT is not set
 CONFIG_CPU_SUPPORTS_PM_TIMER_EMULATION=y
 CONFIG_HAVE_HYPERTHREADING=y
-# CONFIG_FSP_HYPERTHREADING is not set
+CONFIG_FSP_HYPERTHREADING=y
 # CONFIG_INTEL_KEYLOCKER is not set
 # CONFIG_SOC_INTEL_COMMON_BLOCK_PRMRR_SIZE_MAX is not set
 # CONFIG_SOC_INTEL_COMMON_BLOCK_PRMRR_SIZE_256MB is not set
@@ -506,7 +506,7 @@ CONFIG_EC_LENOVO_H8=y
 CONFIG_H8_BEEP_ON_DEATH=y
 CONFIG_H8_FLASH_LEDS_ON_DEATH=y
 CONFIG_H8_SUPPORT_BT_ON_WIFI=y
-# CONFIG_H8_FN_CTRL_SWAP is not set
+CONFIG_H8_FN_CTRL_SWAP=y
 CONFIG_H8_HAS_BAT_THRESHOLDS_IMPL=y
 CONFIG_H8_HAS_PRIMARY_FN_KEYS=y
 CONFIG_H8_HAS_LEDLOGO=y
diff --git a/config/coreboot/t480_vfsp_16mb/target.cfg b/config/coreboot/t480_vfsp_16mb/target.cfg
index 1cc6d167..199c5c20 100644
--- a/config/coreboot/t480_vfsp_16mb/target.cfg
+++ b/config/coreboot/t480_vfsp_16mb/target.cfg
@@ -2,8 +2,8 @@

 tree="default"
 xarch="i386-elf"
-payload_seabios="y"
 payload_grub="y"
+payload_grubsea="y"
 payload_memtest="y"
 grub_scan_disk="nvme ahci"
 grubtree="xhci_nvme"
diff --git a/config/grub/xhci_nvme/config/payload b/config/grub/xhci_nvme/config/payload
index 9db22fe2..f6158379 100644
--- a/config/grub/xhci_nvme/config/payload
+++ b/config/grub/xhci_nvme/config/payload
@@ -51,11 +51,7 @@ fi


 set default="0"
-if [ -f (cbfsdisk)/timeout.cfg ]; then
-	source (cbfsdisk)/timeout.cfg
-else
-	set timeout=8
-fi
+set timeout=0
 set grub_scan_disk="nvme ahci ata"
 if [ -f (cbfsdisk)/scan.cfg ]; then
 	source (cbfsdisk)/scan.cfg
--
2.49.0
